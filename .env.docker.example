# Staqq monolith — copy to .env.docker on the VPS and fill in. chmod 600.
# .env.docker is gitignored. Compose injects these into web + worker.

# ── Public (baked into client bundle at build) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://staqq.in

# ── Supabase (server) ──
SUPABASE_SERVICE_ROLE_KEY=

# ── Local Redis via SRH (pick any long random string; used by srh + app) ──
SRH_TOKEN=change-me-to-a-long-random-string

# ── Angel One (price worker + any live endpoints) ──
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_CODE=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=

# ── Worker cadence ──
REFRESH_MS=30000
REFRESH_MS_CLOSED=600000

# ── Other services as needed (email, razorpay, crypto APIs, etc.) ──
# EMAIL_PROVIDER=
# BREVO_API_KEY=
# RAZORPAY_KEY_ID=
# ... add the rest of your runtime env here
